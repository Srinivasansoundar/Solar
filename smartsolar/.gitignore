# ── Virtual environments ──────────────────────────────────────────────────────
myenv/
venv/
env/
.venv/

# ── Saved model files (too large for GitHub — download from Google Drive) ─────
saved_models/
energy_consumption_saved_models/

# ── Tariff model weights ──────────────────────────────────────────────────────
# tariff_lstm_weights.pth (~2MB) is committed to Git so the Streamlit frontend
# can access it. The force-include rules appear AFTER *.pth below.

# ── Model file extensions ─────────────────────────────────────────────────────
*.pkl
*.h5
*.pt
*.pth
# Force-include the tariff weights (small enough to track in Git)
!smartsolar/tariff_forcasting_model/tariff_lstm_weights.pth
!tariff_forcasting_model/tariff_lstm_weights.pth

# ── Streamlit secrets (never commit) ──────────────────────────────────────────
.streamlit/secrets.toml

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Data files (ignore raw data; keep sample CSVs in frontend/) ──────────────
*.csv
*.xlsx
*.xls
# Allow sample CSVs used for testing the app
!smartsolar/frontend/sample_solar.csv
!smartsolar/frontend/sample_consumption_24h.csv
!smartsolar/frontend/sample_tariff.csv
!frontend/sample_solar.csv
!frontend/sample_consumption_24h.csv
!frontend/sample_tariff.csv

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
uvicorn.log

# ── Temp files ────────────────────────────────────────────────────────────────
gitstatus.txt
untracked.txt